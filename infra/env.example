# NetTwin-SOC Environment Variables
# Copy this file to .env and configure

# Database
# For development (SQLite):
DATABASE_URL=sqlite:///./data/nettwin.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql://nettwin:nettwin_secret@db:5432/nettwin

# Data storage directory
DATA_DIR=./data

# Debug mode
DEBUG=false

# Frontend configuration
NEXT_PUBLIC_API_MODE=real
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: Detection model parameters (JSON string)
MODEL_PARAMS={}
